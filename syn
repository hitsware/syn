<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8" />
<title>Mini-Pi Synth</title>
<style>
body {
  font-family: sans-serif;
  background: #111;
  color: #eee;
  padding: 20px;
}
button {
  padding: 10px 20px;
  margin: 5px;
  font-size: 16px;
}
textarea {
  width: 100%;
  height: 200px;
  margin-top: 10px;
  background: #222;
  color: #0f0;
  font-family: monospace;
  padding: 10px;
}
</style>
</head>
<body>

<h1>Mini-Pi Synth</h1>
<p>A tiny Sonic‑Pi‑style browser synth.</p>

<button id="run">Run Code</button>

<textarea id="code">
// Example:
// play(440)
// sleep(0.5)
// play(660)

play(440)
sleep(0.25)
play(660)
sleep(0.25)
play(880)
</textarea>

<script>
let audioCtx = null;

function ensureAudio() {
  if (!audioCtx) {
    audioCtx = new (window.AudioContext || window.webkitAudioContext)();
  }
}

function play(freq, dur = 0.3) {
  ensureAudio();
  const osc = audioCtx.createOscillator();
  const gain = audioCtx.createGain();
  osc.frequency.value = freq;
  osc.type = "sine";
  osc.connect(gain);
  gain.connect(audioCtx.destination);
  gain.gain.setValueAtTime(0.2, audioCtx.currentTime);
  gain.gain.exponentialRampToValueAtTime(0.0001, audioCtx.currentTime + dur);
  osc.start();
  osc.stop(audioCtx.currentTime + dur);
}

function sleep(t) {
  return new Promise(res => setTimeout(res, t * 1000));
}

async function runCode() {
  const text = document.getElementById("code").value;
  const lines = text.split("\n").map(l => l.trim()).filter(l => l);

  for (const line of lines) {
    if (line.startsWith("play(")) {
      const num = Number(line.slice(5, -1));
      play(num);
    } else if (line.startsWith("sleep(")) {
      const num = Number(line.slice(6, -1));
      await sleep(num);
    }
  }
}

document.getElementById("run").onclick = runCode;
</script>

</body>
</html>
